# ─── Sanity ───────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → API

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# Server-only — never expose to client
SANITY_API_READ_TOKEN=your_read_token_here

# Shared secret for the /api/revalidate webhook
# Set the same value in Sanity webhook settings
SANITY_WEBHOOK_SECRET=a_long_random_secret_string

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://descf.org

# ─── Sanity Studio ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_STUDIO_URL=https://studio.descf.org

# ─── Optional — for Vercel preview environments ───────────────────────────────
# NEXT_PUBLIC_VERCEL_ENV=preview
